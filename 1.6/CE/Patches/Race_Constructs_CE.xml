<?xml version="1.0" encoding="UTF-8"?>
<Patch>

    <Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/ThingDef[defName="DMST_Construct_Gargoyle"]</xpath>
		<value>
			<li Class="CombatExtended.RacePropertiesExtensionCE">
				<bodyShape>Humanoid</bodyShape>
			</li>
		</value>
	</Operation>

    <Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="DMST_Construct_Gargoyle"]/statBases</xpath>
		<value>
			<CarryWeight>20</CarryWeight>
			<CarryBulk>20</CarryBulk>
			<AimingAccuracy>0.75</AimingAccuracy>
			<ShootingAccuracyPawn>0.8</ShootingAccuracyPawn>
			<MeleeDodgeChance>0.07</MeleeDodgeChance>
			<MeleeCritChance>0.03</MeleeCritChance>
			<MeleeParryChance>0.03</MeleeParryChance>
			<MaxHitPoints>200</MaxHitPoints>
            <SmokeSensitivity>0</SmokeSensitivity>
		</value>
    </Operation>
	
    <Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DMST_Construct_Gargoyle"]/statBases/ArmorRating_Blunt</xpath>
		<value>
			<ArmorRating_Blunt>4</ArmorRating_Blunt>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DMST_Construct_Gargoyle"]/statBases/ArmorRating_Sharp</xpath>
		<value>
			<ArmorRating_Sharp>2</ArmorRating_Sharp>
		</value>
	</Operation>
			
    <Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DMST_Construct_Gargoyle"]/statBases/ArmorRating_Heat</xpath>
		<value>
			<ArmorRating_Heat>0.05</ArmorRating_Heat>
		</value>
    </Operation>

    <Operation Class="PatchOperationConditional">
		<xpath>Defs/ThingDef[defName="DMST_Construct_Gargoyle"]/comps</xpath>
			<nomatch Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="DMST_Construct_Gargoyle"]</xpath>
				<value>
    				<comps />
				</value>
			</nomatch>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="DMST_Construct_Gargoyle"]/comps</xpath>
		<value>
			<li Class="CombatExtended.CompProperties_ArmorDurability">
				<Durability>380</Durability>
				<Regenerates>false</Regenerates>
				<Repairable>true</Repairable>
				<RepairIngredients>
				    <Steel>3</Steel>
				</RepairIngredients>
				<RepairTime>200</RepairTime>
				<RepairValue>200</RepairValue>
				<CanOverHeal>true</CanOverHeal>
				<MaxOverHeal>30</MaxOverHeal>
				<MinArmorPct>0.6</MinArmorPct>
			</li>
		</value>
	</Operation>

    <Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DMST_Construct_Gargoyle"]/tools</xpath>
		<value>
			<tools>
                <li Class="CombatExtended.ToolCE">
					<label>head</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>15</power>
					<cooldownTime>5.56</cooldownTime>
					<armorPenetrationSharp>0</armorPenetrationSharp>
					<armorPenetrationBlunt>1.65</armorPenetrationBlunt>
					<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
					<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>left fist</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>8</power>
					<cooldownTime>2.3</cooldownTime>
					<armorPenetrationSharp>0</armorPenetrationSharp>
					<armorPenetrationBlunt>1.44</armorPenetrationBlunt>
					<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
				</li>
				<li Class="CombatExtended.ToolCE">
					<label>right fist</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>8</power>
					<cooldownTime>2.3</cooldownTime>
					<armorPenetrationSharp>0</armorPenetrationSharp>
					<armorPenetrationBlunt>1.44</armorPenetrationBlunt>
					<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
				</li>
			</tools>
		</value>
	</Operation>


</Patch>