<?xml version="1.0" encoding="UTF-8"?>
<Patch>

    <!-- ========== Magier Helmet ========== -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DMST_Apparel_MagierHelmet"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>5</StuffEffectMultiplierArmor>
			<Bulk>4</Bulk>
			<WornBulk>2.5</WornBulk>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="DMST_Apparel_MagierHelmet"]</xpath>
		<value>
			<stuffCategories>
                <li>Metallic</li>
            </stuffCategories>
		</value>
	</Operation>

    <Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DMST_Apparel_MagierCloak"]/statBases/StuffEffectMultiplierArmor</xpath>
		<value>
			<StuffEffectMultiplierArmor>5</StuffEffectMultiplierArmor>
		</value>
	</Operation>

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="DMST_Apparel_MagierCloak"]/statBases</xpath>
		<value>
			<Bulk>6</Bulk>
			<WornBulk>3</WornBulk>
		</value>
	</Operation>

</Patch>