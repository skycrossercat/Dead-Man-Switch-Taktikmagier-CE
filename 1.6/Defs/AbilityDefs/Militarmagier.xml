<?xml version="1.0" encoding="UTF-8"?>
<Defs>
	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>DMS_Flash</defName>
		<label>Assault flash</label>
		<description>透過引導靈能震動空間來產生爆發性的定向強光與噪音，其威力足以使扇形波及範圍內的生物與機械傳感器短暫失明，這經常被用於針對施法者的戰鬥，並輔以槍械在對方失明時給上致命一擊。</description>
		<iconPath>Abilities/Militarmagier/flashlight</iconPath>
		<range>10.9</range>
		<radius>12</radius>
		<castTime>15</castTime>
		<durationTime>300</durationTime>
		<cooldownTime>3600</cooldownTime>
		<abilityClass>Militarmagier.Ability_Flash</abilityClass>
		<targetMode>Location</targetMode>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>DMST_Militarmagier</path>
				<level>1</level>
				<order>1</order>
				<psyfocusCost>0.05</psyfocusCost>
				<entropyGain>25</entropyGain>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>

