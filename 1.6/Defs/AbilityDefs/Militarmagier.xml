	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>DMST_QuickDraw</defName>
		<label>quick draw</label>
		<description>透過電流的直接刺激來使身體透過反射動作來在片刻間完成槍械的瞄準與開火，這種被稱為槍鬥術的近距離射擊技巧能夠有效的對威脅做出快速反應，也經常被直接用來進行近身格鬥。</description>
		<iconPath>Abilities/Militarmagier/quickdraw</iconPath>
		<castTime>0</castTime>
		<durationTime>300</durationTime>
		<cooldownTime>600</cooldownTime>
		<abilityClass>VEF.Abilities.Ability_Blank</abilityClass>
		<targetMode>Self</targetMode>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>DMST_Militarmagier</path>
				<level>3</level>
				<order>2</order>
				<psyfocusCost>0.01</psyfocusCost>
				<entropyGain>10</entropyGain>
			</li>
			<li Class="VEF.Abilities.AbilityExtension_Hediff">
				<hediff>DMST_QuickDraw</hediff>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>

	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>DMST_EmpBurst</defName>
		<label>emp burst</label>
		<description>引導靈能扭曲周圍的磁場線來憑空製造出一個巨大的電磁脈衝，能夠有效的使範圍內的敵人受到EMP以及磁場干擾所導致的嚴重不適。</description>
		<iconPath>Abilities/Militarmagier/empBurst</iconPath>
		<castTime>60</castTime>
		<cooldownTime>3600</cooldownTime>
		<abilityClass>VEF.Abilities.Ability_Explode</abilityClass>
		<radius>14.9</radius>
		<targetMode>Self</targetMode>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>DMST_Militarmagier</path>
				<level>4</level>
				<order>1</order>
				<psyfocusCost>0.01</psyfocusCost>
				<entropyGain>10</entropyGain>
			</li>
			<li Class="VEF.Abilities.AbilityExtension_Explosion">
				<explosionRadius>14.9</explosionRadius>
				<onCaster>true</onCaster>
				<explosionDamageDef>EMP</explosionDamageDef>
				<explosionDamageAmount>40</explosionDamageAmount>
				<casterImmune>true</casterImmune>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>

	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>DMST_FieldAid</defName>
		<label>field aid</label>
		<description>透過刺激患者傷口的皮膚組織增生來封閉開放性創口，被用於在交戰中為重傷的同伴或自身快速止血。這是一個非常講求施術者技巧的施法，但同時也是每一個軍術士在訓練時都被要求熟練掌握的基本施法。</description>
		<iconPath>Abilities/Militarmagier/heal</iconPath>
		<range>3.9</range>
		<castTime>300</castTime>
		<cooldownTime>600</cooldownTime>
		<abilityClass>VEF.Abilities.Ability_Blank</abilityClass>
		<targetingParameters>
			<canTargetPawns>true</canTargetPawns>
			<canTargetBuildings>false</canTargetBuildings>
			<canTargetSelf>true</canTargetSelf>
		</targetingParameters>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>DMST_Militarmagier</path>
				<level>4</level>
				<order>2</order>
				<psyfocusCost>0.04</psyfocusCost>
				<entropyGain>20</entropyGain>
			</li>
			<li Class="Militarmagier.AbilityExtension_Heal">
				<tendQualityRange>0.4~0.8</tendQualityRange>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>

	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>DMST_ForceWake</defName>
		<label>force wake</label>
		<description>透過靈能干涉來強制大腦保持清醒意識並潛意識的用樂觀情緒催眠自己，這對於那些在戰場上高度警惕的施術者們執行長時間任務時十分有用。但頻繁的使用可能會累積大量神經熱而適得其反。</description>
		<iconPath>Abilities/Militarmagier/forceWake</iconPath>
		<castTime>120</castTime>
		<cooldownTime>1200</cooldownTime>
		<abilityClass>VEF.Abilities.Ability_Blank</abilityClass>
		<targetMode>Self</targetMode>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>DMST_Militarmagier</path>
				<level>5</level>
				<order>1</order>
				<psyfocusCost>0.04</psyfocusCost>
				<entropyGain>14</entropyGain>
			</li>
			<li Class="Militarmagier.AbilityExtension_Calm">
				<thought>DMST_ForceWake</thought>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>

	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>DMST_Demolish</defName>
		<label>demolish</label>
		<description>透過對事物構造的了解，軍術士們能夠直接操作零件的位置來甚至在分子層面上斷開纏結的分子鏈，以此來達到將物體解體的能力。這項技巧被廣泛用於爆炸物拆除與癱瘓精密設備，並對建築與砲塔這樣的靜態物體來說非常合適。</description>
		<iconPath>Abilities/Militarmagier/demolish</iconPath>
		<range>10.9</range>
		<castTime>90</castTime>
		<cooldownTime>1200</cooldownTime>
		<abilityClass>VEF.Abilities.Ability_Blank</abilityClass>
		<targetingParameters>
			<canTargetPawns>false</canTargetPawns>
		</targetingParameters>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>DMST_Militarmagier</path>
				<level>5</level>
				<order>2</order>
				<psyfocusCost>0.04</psyfocusCost>
				<entropyGain>10</entropyGain>
			</li>
			<li Class="Militarmagier.AbilityExtension_Destroy">
				<destroyPoints>800</destroyPoints>
				<undestroyFactor>0.25</undestroyFactor>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>
</Defs>