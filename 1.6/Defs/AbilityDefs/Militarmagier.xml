	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>DMS_ConstructTurret</defName>
		<label>assemble turret construct</label>
		<description>將施術者的少量心靈熵轉化為形而上的水晶，並以標準生產的沖壓零件作為骨架來組裝成一個臨時的自動砲塔。該砲塔透過注入的能量來維持其索敵與開火，並在被摧毀時爆炸。</description>
		<iconPath>Abilities/Militarmagier/summonTurret</iconPath>
		<range>8.9</range>
		<castTime>180</castTime>
		<cooldownTime>1200</cooldownTime>
		<abilityClass>VEF.Abilities.Ability_Blank</abilityClass>
		<targetingParameters>
			<canTargetItems>true</canTargetItems>
			<mapObjectTargetsMustBeAutoAttackable>false</mapObjectTargetsMustBeAutoAttackable>
			<thingCategory>Item</thingCategory>
			<canTargetLocations>false</canTargetLocations>
			<canTargetPawns>false</canTargetPawns>
			<canTargetBuildings>false</canTargetBuildings>
		</targetingParameters>
		<modExtensions>
			<li Class="VanillaPsycastsExpanded.AbilityExtension_Psycast">
				<path>DMST_Militarmagier</path>
				<level>3</level>
				<order>1</order>
				<psyfocusCost>0.01</psyfocusCost>
				<entropyGain>5</entropyGain>
			</li>
			<li Class="Militarmagier.AbilityExtension_Construct">
				<constructDef>DMST_Turret_Sentry</constructDef>
				<costDef>ComponentStamped</costDef>
				<heat>50</heat>
			</li>
			<li Class="VEF.Abilities.AbilityExtension_FleckOnTarget">
				<fleckDefs>
					<li>PsycastSkipInnerExit</li>
					<li>PsycastSkipOuterRingExit</li>
				</fleckDefs>
				<scale>0.42</scale>
				<sound>Psycast_Skip_Exit</sound>
				<preCastTicks>10</preCastTicks>
			</li>
			<li Class="VEF.Abilities.AbilityExtension_EffecterOnTarget">
				<effecterDef>Skip_Exit</effecterDef>
				<maintainForTicks>60</maintainForTicks>
				<scale>0.42</scale>
			</li>
		</modExtensions>
	</VEF.Abilities.AbilityDef>

	<VEF.Abilities.AbilityDef ParentName="VPE_PsycastBase">
		<defName>DMS_ConstructPawn</defName>
