<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- 戰術女巫頭盔 -->
	<ThingDef ParentName="DMS_ArmorHelmetMakeableBase">
		<defName>DMST_Apparel_MagierHelmet</defName>
		<label>Magier helmet</label>
		<description>A psychic helmet worn by magiers, Based on a tactical helmet and covered with a high conical hat made of military-standard fiber. Its surface has a psychically powered active camouflage, but complete invisibility requires wearing a magier cloak.</description>
		<recipeMaker>
			<researchPrerequisite>FlakArmor</researchPrerequisite>
			<skillRequirements>
				<Crafting>10</Crafting>
			</skillRequirements>
			<recipeUsers>
				<li>DMS_TableMachinePrinter</li>
			</recipeUsers>
			<displayPriority>205</displayPriority>
		</recipeMaker>
		<graphicData>
			<texPath>Apparel/MagierHelemt/headGear_Icon</texPath>
		</graphicData>
		<uiIconScale>1</uiIconScale>
		<statBases>
			<WorkToMake>20000</WorkToMake>
			<MaxHitPoints>150</MaxHitPoints>
			<Mass>1.5</Mass>
			<StuffEffectMultiplierArmor>1.1</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.18</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.18</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>1.75</EquipDelay>
		</statBases>
		<costStuffCount>50</costStuffCount>
		<costList>
			<ComponentStamped>1</ComponentStamped>
			<VPE_Eltex MayRequire="vanillaexpanded.vpsycastse">4</VPE_Eltex>
			<Polyester>20</Polyester>
		</costList>
		<equippedStatOffsets>
			<PsychicSensitivityOffset>0.10</PsychicSensitivityOffset>
			<PsychicEntropyRecoveryRate>0.05</PsychicEntropyRecoveryRate>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.2</SlaveSuppressionOffset>
		</equippedStatOffsets>
		<apparel>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
			<bodyPartGroups>
				<li>UpperHead</li>
			</bodyPartGroups>
			<wornGraphicPath>Apparel/MagierHelemt/headGear</wornGraphicPath>
			<layers>
				<li>Overhead</li>
			</layers>
			<tags Inherit="False">
				<li>DMST_Magier</li>
			</tags>
		</apparel>
		<colorGenerator Class="ColorGenerator_Options">
			<options>
				<li>
					<weight>10</weight>
					<only>(0.4,0.3,0.15)</only>
				</li>
			</options>
		</colorGenerator>
	</ThingDef>

	<!-- 戰術斗篷，給戰術女巫和狙擊手用的 -->
	<ThingDef ParentName="ApparelMakeableBase">
		<defName>DMST_Apparel_MagierCloak</defName>
		<label>Magier cloak</label>
		<description>An active optical camouflage cloak equipped by magiers. It has an active camouflage ability driven by psychic power, which consumes psychic entropy. requires a magier helmet to be effective.</description>
		<recipeMaker />
		<graphicData>
			<texPath>Things/Apparel/MagierCloak/icon</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>0.9</drawSize>
		</graphicData>
		<stuffCategories>
			<li>Fabric</li>
		</stuffCategories>
		<thingCategories>
			<li>ApparelMisc</li>
		</thingCategories>
		<statBases>
			<WorkToMake>20000</WorkToMake>
			<MaxHitPoints>200</MaxHitPoints>
			<Mass>3</Mass>
			<Flammability>0</Flammability>
			<StuffEffectMultiplierArmor>0.35</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.5</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>1</StuffEffectMultiplierInsulation_Heat>
			<EquipDelay>1.5</EquipDelay>
		</statBases>
		<costStuffCount>100</costStuffCount>
		<equippedStatOffsets>
			<PsychicSensitivityOffset>0.10</PsychicSensitivityOffset>
			<PsychicEntropyRecoveryRate>0.05</PsychicEntropyRecoveryRate>
			<PsychicEntropyMax>0.75</PsychicEntropyMax>
			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.2</SlaveSuppressionOffset>
		</equippedStatOffsets>
		<costList>
			<ComponentStamped>1</ComponentStamped>
			<VPE_Eltex MayRequire="vanillaexpanded.vpsycastse">4</VPE_Eltex>
			<Polyester>40</Polyester>
			<DMS_Ceramics>60</DMS_Ceramics>
		</costList>
		<apparel>
			<countsAsClothingForNudity>true</countsAsClothingForNudity>
			<legsNakedUnlessCoveredBySomethingElse>true</legsNakedUnlessCoveredBySomethingElse>
			<shellRenderedBehindHead>true</shellRenderedBehindHead>
			<canBeDesiredForIdeo>false</canBeDesiredForIdeo>
			<bodyPartGroups>
				<li>Torso</li>
				<li>Neck</li>
				<li>Shoulders</li>
			</bodyPartGroups>
			<wornGraphicPath>Things/Apparel/MagierCloak/apparel</wornGraphicPath>
			<layers>
				<li>Shell</li>
			</layers>
			<blocksAddedPartWoundGraphics>true</blocksAddedPartWoundGraphics>
			<tags>
				<li>DMST_Magier</li>
			</tags>
			<defaultOutfitTags>
				<li>Soldier</li>
			</defaultOutfitTags>
			<abilities>
				<li MayRequire="Ludeon.RimWorld.Royalty">DMST_Camouflage</li>
			</abilities>
		</apparel>
	</ThingDef>
</Defs>