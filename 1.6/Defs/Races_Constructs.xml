<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="VPE_ConstructBase">
		<defName>DMST_Construct_Gargoyle</defName>
		<label>gargoyle</label>
		<description>assembled components which animated by powerful psychic energy. It will engage nearby threats and defend the master from any harm that may come to them.\n\n&lt;color=#E5E54C&gt;Gameplay effect:&lt;/color&gt;Constructs generate constant heat for the caster that summoned them. Keeping too many constructs alive could prevent the psycaster from casting other abilities.</description>
		<thingClass>Militarmagier.Pawn_ConstructWeaponUsable</thingClass>
		<statBases>
			<ComfyTemperatureMin>-100</ComfyTemperatureMin>
			<ComfyTemperatureMax>250</ComfyTemperatureMax>
			<MarketValue>150</MarketValue>
			<MoveSpeed>4.2</MoveSpeed>
			<ArmorRating_Sharp>0.4</ArmorRating_Sharp><!--銳抗-->
			<ArmorRating_Blunt>0.1</ArmorRating_Blunt><!--鈍抗-->
			<ArmorRating_Heat>0.5</ArmorRating_Heat>  <!--能抗-->
		</statBases>
		<tools>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>14</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
			<li>
				<label>left fist</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>12.0</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
				<alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
			</li>
			<li>
				<label>right fist</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>12.0</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
				<alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
			</li>
		</tools>
		<comps>
			<li Class="VEF.AnimalBehaviours.CompProperties_InitialHediff">
				<hediffname>VPE_NoPain</hediffname>
				<hediffseverity>1</hediffseverity>
			</li>
			<li Class="VEF.AnimalBehaviours.CompProperties_Draftable">
				<makeNonFleeingToo>true</makeNonFleeingToo>
			</li>
			<li Class="VanillaPsycastsExpanded.CompProperties_BreakLink">
				<gizmoImage>Effects/Technomancer/BreakLink/BreakLinkSteelConstruct</gizmoImage>
				<gizmoLabel>VPE_BreakLink</gizmoLabel>
				<gizmoDesc>VPE_BreakLinkDesc</gizmoDesc>
			</li>
			<li Class="VEF.AnimalBehaviours.CompProperties_DiseaseImmunity">
				<hediffsToRemove>
					<li>Animal_Plague</li>
					<li>Animal_Flu</li>
					<li>AB_AnimalSporesAllergy</li>
				</hediffsToRemove>
				<tickInterval>2000</tickInterval>
			</li>
			<li Class="VEF.AnimalBehaviours.CompProperties_DiseaseEventImmunity" />
		</comps>
		<race>
			<deathAction>
				<workerClass>VanillaPsycastsExpanded.DeathActionWorker_SlagChunk</workerClass>
			</deathAction>
			<bloodDef>VPE_Filth_Metal</bloodDef>
			<body>DMS_Humanoid_Soldat</body>
			<baseBodySize>1</baseBodySize>
			<baseHealthScale>1</baseHealthScale>
			<fleshType>VPE_SteelConstructFlesh</fleshType>
			<lifeStageAges>
				<li>
					<minAge>0</minAge>
					<def>AnimalAdult</def>
					<soundWounded>Pawn_Mech_Cleansweeper_Wounded</soundWounded>
					<soundDeath>Pawn_Mech_Cleansweeper_Death</soundDeath>
					<soundCall>DMS_Pawn_Mech_Call</soundCall>
					<soundAngry>VPE_Pawn_SteelConstruct_Angry</soundAngry>
				</li>
			</lifeStageAges>
			<soundCallIntervalRange>
				<min>12000</min>
				<max>20000</max>
			</soundCallIntervalRange>
		</race>
		<modExtensions>
			<li Class="Fortified.MechWeaponExtension">
				<EnableWeaponFilter>true</EnableWeaponFilter>
				<UsableWeaponTags>
					<li>SimpleGun</li>
					<li>ShortShots</li>
					<li>CE_SMG</li>
					<li>DMS_MechWeaponLight</li>
					<li>IndustrialGun</li>
				</UsableWeaponTags>
				<EnableTechLevelFilter>true</EnableTechLevelFilter>
				<UsableTechLevels>
					<li>Industrial</li>
				</UsableTechLevels>
				<BypassUsableWeapons />
			</li>
			<li Class="Fortified.TurretMannableExtension">
				<mannableByDefault>false</mannableByDefault>
				<BypassMannable>
					<li MayRequire="Aoba.Fortress.Industrial">FT_TurretAT</li>
					<li MayRequire="Aoba.Fortress.Industrial">FT_Maxim4M</li>
					<li MayRequire="Aoba.Fortress.Industrial">FT_AutoCannon</li>
					<li MayRequire="Aoba.Fortress.Frontier">FT_GPMG</li>
					<li MayRequire="Aoba.Fortress.Frontier">FT_HeavyMachinegun</li>
					<li MayRequire="Aoba.Fortress.Frontier">FT_InfantryAutoCannon</li>
				</BypassMannable>
			</li>
		</modExtensions>
	</ThingDef>

	<PawnKindDef ParentName="AnimalKindBase">
		<defName>DMST_Construct_Gargoyle</defName>
		<label>gargoyle</label>
		<race>DMST_Construct_Gargoyle</race>
		<combatPower>80</combatPower>
		<canArriveManhunter>false</canArriveManhunter>
		<ecoSystemWeight>1</ecoSystemWeight>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Mech/gargoyle</texPath>
					<drawSize>1.6</drawSize>
					<drawOffset>(0,0,0.1)</drawOffset>
					<shadowData>
						<volume>(0.3,1,0.3)</volume>
						<offset>(0,0,-0.2)</offset>
					</shadowData>
				</bodyGraphicData>
			</li>
		</lifeStages>
	</PawnKindDef>
</Defs>